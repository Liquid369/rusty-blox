# ========================================
# RustyBlox Configuration Example
# ========================================
# Copy this file to config.toml and edit the values below.

[paths]
# Database path for RocksDB storage
db_path = "./data/blocks.db"

# Directory containing PIVX blockchain files (blk*.dat)
# Linux:   ~/.pivx/blocks
# macOS:   ~/Library/Application Support/PIVX/blocks
# Windows: %APPDATA%\PIVX\blocks
blk_dir = "/path/to/PIVX/blocks"

# PIVX data directory (parent of blocks/, contains the LevelDB block index)
pivx_data_dir = "/path/to/PIVX"

# Where to copy PIVX Core's block-index LevelDB for safe read-only parsing while
# the daemon is running (avoids read locks). Recreated as needed.
block_index_copy_dir = "/tmp/pivx_block_index_current"

# Where to copy PIVX Core's chainstate LevelDB (only used by the optional
# chainstate-based UTXO verification path; see use_chainstate_for_utxos).
chainstate_copy_dir = "/tmp/pivx_chainstate_current"

# Directory the web server serves the built frontend from.
# Default: frontend-legacy/dist (build with: cd frontend-legacy && npm run build)
frontend_dist = "frontend-legacy/dist"

[sync]
# Resync mode: clear all databases and rebuild from scratch on the next start.
resync = false

# Start the sync service automatically on launch.
# false = start the web server in read-only mode against the existing DB.
auto_start = true

# Fast sync: skip UTXO tracking during the initial sync for a large speedup.
# Recommended: true (address data is built afterward by enrich_addresses).
fast_sync = true

# Build the address index from transactions after sync completes (enables address
# lookups + balances). Recommended: true for an explorer.
enrich_addresses = true

# UTXO/balance source of truth. The default (false) = transaction-based enrichment
# scans all transparent history and is what the explorer relies on. Setting this
# true reads Core's chainstate, which only holds CURRENT unspent outputs (no
# history) — useful for VERIFICATION, not as the primary source. Recommended: false.
use_chainstate_for_utxos = false

# Use PIVX Core's block index to resolve transaction heights before enrichment.
# Eliminates the slow repair phase and marks orphans correctly. Recommended: true.
use_block_index_for_heights = true

# Parallel blk*.dat parse workers. The parse is CPU-bound, so match your core
# count for the fastest parse; lower it to leave CPU for other services.
parallel_files = 8

# Address-enrichment parallelism (Pass 1 / Pass 2b). 1 = serial (default, lowest
# RAM). 2..=4 = range-sharded across the txid keyspace (faster, more RAM; values
# above 4 are clamped to 4). Raise only on a box with spare cores + RAM.
enrich_parallel_shards = 1

# Validate the offset-based block reader against the scanner after sync (writes
# extra 'o' offset keys; must be set BEFORE the initial sync to take effect).
# Recommended: false (testing/validation only).
validate_offset_indexing = false

[rocksdb]
# Memtable RAM. db_write_buffer_size is a HARD global ceiling across ALL column
# families; write_buffer_size x max_write_buffer_number is only the per-CF shape.
write_buffer_size = 256              # MB per column family
max_write_buffer_number = 4
min_write_buffer_number_to_merge = 2
db_write_buffer_size = 1024          # MB global memtable ceiling (0 = unlimited)
block_cache_size = 512               # MB shared read cache

# File + compaction tuning
target_file_size_base = 256          # MB per SST file
max_open_files = 5000
level0_file_num_compaction_trigger = 8
level0_slowdown_writes_trigger = 20
level0_stop_writes_trigger = 36

# Parallelism
max_background_jobs = 8              # background compaction/flush threads
max_subcompactions = 4

# Compression + write concurrency
compression_type = "lz4"            # none | snappy | zstd | lz4 | zlib
enable_pipelined_write = true
allow_concurrent_memtable_write = true
enable_write_thread_adaptive_yield = true

[rpc]
# PIVX Core RPC connection (must match your pivx.conf).
host = "http://127.0.0.1:51472"
user = "your_rpc_username"
pass = "your_secure_rpc_password"

[server]
# Web server bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only).
host = "0.0.0.0"
port = 3005

# Allowed WebSocket origins, comma-separated (e.g. "https://explorer.example.com").
# Leave empty to apply the default same-origin policy.
ws_allowed_origins = ""

# Web server worker threads (string).
worker_threads = "4"
