# ========================================
# RustyBlox Configuration Example
# ========================================
# Copy this file to config.toml and edit the values below.

[paths]
# Database path for RocksDB storage
db_path = "./data/blocks.db"

# Directory containing PIVX blockchain files (blk*.dat)
# Linux:   ~/.pivx/blocks
# macOS:   ~/Library/Application Support/PIVX/blocks
# Windows: %APPDATA%\PIVX\blocks
blk_dir = "/path/to/PIVX/blocks"

# PIVX data directory (parent of blocks/, contains the LevelDB block index)
pivx_data_dir = "/path/to/PIVX"

# Where to copy PIVX Core's block-index LevelDB for safe read-only parsing while
# the daemon is running (avoids read locks). Recreated as needed.
block_index_copy_dir = "/tmp/pivx_block_index_current"

# Where to copy PIVX Core's chainstate LevelDB (only used by the optional
# chainstate-based UTXO verification path; see use_chainstate_for_utxos).
chainstate_copy_dir = "/tmp/pivx_chainstate_current"

# Directory the web server serves the built frontend from.
# Default: frontend/dist — the redesigned UI (build with: cd frontend && npm install && npm run build).
# The previous UI is still available at frontend-legacy/dist if you prefer it.
frontend_dist = "frontend/dist"

[sync]
# Resync mode: clear all databases and rebuild from scratch on the next start.
resync = false

# Start the sync service automatically on launch.
# false = start the web server in read-only mode against the existing DB.
auto_start = true

# Fast sync: skip UTXO tracking during the initial sync for a large speedup.
# Recommended: true (address data is built afterward by enrich_addresses).
fast_sync = true

# Build the address index from transactions after sync completes (enables address
# lookups + balances). Recommended: true for an explorer.
enrich_addresses = true

# UTXO/balance source of truth. The default (false) = transaction-based enrichment
# scans all transparent history and is what the explorer relies on. Setting this
# true reads Core's chainstate, which only holds CURRENT unspent outputs (no
# history) — useful for VERIFICATION, not as the primary source. Recommended: false.
use_chainstate_for_utxos = false

# Use PIVX Core's block index to resolve transaction heights before enrichment.
# Eliminates the slow repair phase and marks orphans correctly. Recommended: true.
use_block_index_for_heights = true

# Parallel blk*.dat parse workers. The parse is CPU-bound, so match your core
# count for the fastest parse; lower it to leave CPU for other services.
parallel_files = 8

# Address-enrichment parallelism (Pass 1 / Pass 2b). 1 = serial (default, lowest
# RAM). 2..=4 = range-sharded across the txid keyspace (faster, more RAM; values
# above 4 are clamped to 4). Raise only on a box with spare cores + RAM.
enrich_parallel_shards = 1

# Validate the offset-based block reader against the scanner after sync (writes
# extra 'o' offset keys; must be set BEFORE the initial sync to take effect).
# Recommended: false (testing/validation only).
validate_offset_indexing = false

# Live orphan discovery: tail Core's blk*.dat files to capture side-branch/stale
# blocks the RPC tip-poll misses, into the private tail_blocks/tail_meta CFs.
# Pure observer — makes ZERO canonical writes (see DESIGN-live-orphan-capture.md).
# Opt-in; default false. When off, the two private CFs are created empty and unused.
live_tail_blkfiles = false

# Live daily-analytics updater: keep the analytics_tx_day:<date> blobs current as
# the monitor connects blocks (incremental Lane I + window Lane R), instead of only
# at full-enrich time. Opt-in; default false. Activates only AFTER a full enrich
# sets the live-ready gate (a degraded restart rebuild keeps it dark, since its
# join fields are zeroed). See DESIGN-live-analytics-update.md.
live_analytics = false
# Phase-0 shadow mode (default true): write shadow_tx_day:<date> blobs and leave
# the real analytics_tx_day:<date> untouched, for diffing against a full enrich
# before promoting. Set false to write the real blobs once validated.
live_analytics_shadow = true
# One-shot validator: if > 0, after the daily series is built, re-run Lane I/R over
# this many recent days into the shadow keyspace and log a field-by-field diff vs
# the full enrich (integer fields exact; avg_difficulty/coin_days within an epsilon;
# new_addresses skipped). 0 = off. Run a FULL re-enrich first for a true join diff.
live_analytics_shadow_validate_days = 0
# Opt-in: auto-trigger a full re-enrich to re-green the live gate after a deep
# reorg (default false — a full enrich is heavy, so default to logging + a manual
# re-enrich). Only relevant when live_analytics = true.
live_analytics_auto_reenrich = false
# Periodic recompute of the richlist + wealth-distribution snapshots from the live
# addr_index (balance = received - sent per address, the same value /address and
# the full enrich use). Without this the three wealth snapshots refresh ONLY at
# full-enrich time and otherwise stay frozen. Opt-in; default false. It pauses
# automatically after a reorg deeper than the addr_index undo window (200 blocks)
# until a full re-enrich rebuilds the index.
analytics_recompute_enabled = false
# Recompute cadence in blocks (default 60 ≈ hourly at ~1 block/min). Lower = fresher
# richlist at the cost of a periodic O(addresses) addr_index scan.
analytics_recompute_interval_blocks = 60

[rocksdb]
# Memtable RAM. db_write_buffer_size is a HARD global ceiling across ALL column
# families; write_buffer_size x max_write_buffer_number is only the per-CF shape.
write_buffer_size = 256              # MB per column family
max_write_buffer_number = 4
min_write_buffer_number_to_merge = 2
db_write_buffer_size = 1024          # MB global memtable ceiling (0 = unlimited)
block_cache_size = 512               # MB shared read cache

# File + compaction tuning
target_file_size_base = 256          # MB per SST file
max_open_files = 5000
level0_file_num_compaction_trigger = 8
level0_slowdown_writes_trigger = 20
level0_stop_writes_trigger = 36

# Parallelism
max_background_jobs = 8              # background compaction/flush threads
max_subcompactions = 4

# Compression + write concurrency
compression_type = "lz4"            # none | snappy | zstd | lz4 | zlib
enable_pipelined_write = true
allow_concurrent_memtable_write = true
enable_write_thread_adaptive_yield = true

[rpc]
# PIVX Core RPC connection (must match your pivx.conf).
host = "http://127.0.0.1:51472"
user = "your_rpc_username"
pass = "your_secure_rpc_password"

[server]
# Web server bind address. Default 127.0.0.1 = localhost only: the shipped
# ops/nginx-rustyblox.conf reverse-proxies to 127.0.0.1:3005 and every edge control
# (rate limits, method allow-list, /metrics + /cache/stats blocking) assumes the
# backend is NOT directly reachable. Use 0.0.0.0 only if the host firewall blocks
# this port and you intend to expose it (e.g. containerized without a proxy).
host = "127.0.0.1"
port = 3005

# Allowed WebSocket origins, comma-separated (e.g. "https://explorer.example.com").
# Leave empty to apply the default same-origin policy.
ws_allowed_origins = ""

# Web server worker threads (string).
worker_threads = "4"

[repair]
# One-shot heal for historic "stuck heightless" transactions — confirmed txs whose
# stored height was left at -1 by an earlier reorg/catch-up bug (now fixed forward),
# so /tx and /address served them as unconfirmed. When true, on startup (before the
# address enrichment) it re-resolves each affected block's canonical tx list from the
# node via RPC and promotes the stuck records to their real height. Idempotent and
# orphan-safe (it only rewrites txs the node reports as canonical for that height).
# Set true for ONE run to heal an existing DB, then set back to false — while enabled
# it does a full transactions-CF scan on every startup. Default: false.
reresolve_heightless = false

# One-shot cleanup of malformed "phantom stub" 't'+txid records (< 8-byte values that
# can't hold a real tx) which shadow the valid record at the other key order and make
# /tx 404 a transaction that exists. Safe + idempotent. Set true for one run, then false.
# Default: false.
delete_stub_txs = false
